    "eslint-plugin-css-modules": "2.12.0",
    "eslint-plugin-ext": "0.1.0",
    "eslint-plugin-filenames": "1.3.2",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-no-unsanitized": "4.1.2",
    "eslint-plugin-perfectionist": "4.10.1",
